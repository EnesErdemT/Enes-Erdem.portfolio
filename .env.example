# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=Enes Talha Erdem - Portfolio
NEXT_PUBLIC_SITE_DESCRIPTION=Data Science Specialist & Machine Learning Engineer

# Contact Form - Resend API
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Analytics (Optional)
# Google Analytics - Get your Measurement ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel Analytics - Enable in Vercel Dashboard, no ID needed
# Just install: npm install @vercel/analytics
# Then uncomment the import in components/analytics/VercelAnalytics.tsx

# Build Configuration
NEXT_TELEMETRY_DISABLED=1
